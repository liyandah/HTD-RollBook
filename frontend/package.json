{
  "name": "salvation-army-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "npx vite build",
    "build:prod": "npx vite build --mode production",
    "build:mobile": "npx vite build --mode mobile",
    "preview": "vite preview",
    "test": "echo \"No tests configured\" && exit 0",
    "lint": "echo \"No lint configured\" && exit 0",
    "cap:sync": "npm run build:mobile && npx cap sync android",
    "cap:open": "npx cap open android",
    "cap:apk": "npm run cap:sync && cd android && gradlew.bat assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/core": "^6.2.0",
    "axios": "^1.6.2",
