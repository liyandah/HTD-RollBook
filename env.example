# WhatsApp Cloud API Configuration
# DO NOT COMMIT THIS FILE WITH REAL VALUES!
# Copy this to .env or set as environment variables

# WhatsApp Meta Verify Token (for webhook verification)
META_VERIFY_TOKEN=sa_verify_123

# WhatsApp Access Token (from Meta Developer Console)
# Get this from: https://developers.facebook.com/apps/{your-app-id}/whatsapp-business/wa-dev-console/
META_ACCESS_TOKEN=your_temporary_access_token_here

# WhatsApp Phone Number ID (from Meta WhatsApp Test Number)
META_PHONE_NUMBER_ID=952859751239210

# Database Configuration
DATABASE_URL=jdbc:postgresql://localhost:5432/salvation_army_db

# JWT Secret (min 256 bits for HS256)
JWT_SECRET=your-very-long-secret-key-at-least-256-bits-for-hs256-algorithm

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# CORS Allowed Origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
